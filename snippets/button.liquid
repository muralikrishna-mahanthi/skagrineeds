{%- doc -%}
  Intended for use in a block similar to the button block.

  @param {string} link - link to render
  @param {object} [block] - The block

  @example
  {% render 'button', link: '/collections/all' %}
{%- enddoc -%}

{% assign block_settings = block.settings %}

{% if block_settings.use_custom_typography and block_settings.custom_font_family != blank %}
  {% assign font_name_raw = block_settings.custom_font_family | split: ',' | first | remove: "'" | remove: '"' | strip %}
  {% assign font_url = font_name_raw | replace: ' ', '+' %}
  <style>
    @import url('https://fonts.googleapis.com/css2?family={{ font_url }}:wght@{{ block_settings.custom_font_weight }}&display=swap');
  </style>
{% endif %}

<a
  {% if link == blank %}
    role="link"
    aria-disabled="true"
  {% else %}
    href="{{ link }}"
  {% endif %}
  class="
    size-style
    {{ block_settings.style_class }}
    {{ block_settings.style_class }}--{{ block.id }}
    {% if block_settings.use_custom_typography %} custom-typography-override{% endif %}
  "
  style="
    {% render 'size-style', settings: block_settings %}
    {% if block_settings.use_custom_typography %}
      {% assign font_name_raw = block_settings.custom_font_family | split: ',' | first | remove: "'" | remove: '"' | strip %}
      --font-family: '{{ font_name_raw }}', sans-serif;
      --font-size: {{ block_settings.custom_font_size }}px;
      --font-weight: {{ block_settings.custom_font_weight }};
      font-family: '{{ font_name_raw }}', sans-serif;
      font-size: {{ block_settings.custom_font_size }}px;
      font-weight: {{ block_settings.custom_font_weight }};
      {% if block_settings.custom_font_color != blank %}
        --color: {{ block_settings.custom_font_color }};
        color: {{ block_settings.custom_font_color }} !important;
      {% endif %}
      --letter-spacing: {{ block_settings.custom_letter_spacing }}px;
      --word-spacing: {{ block_settings.custom_word_spacing }}px;
      letter-spacing: {{ block_settings.custom_letter_spacing }}px;
      word-spacing: {{ block_settings.custom_word_spacing }}px;
    {% endif %}
  "
  {%- if block_settings.open_in_new_tab -%}
    target="_blank"
    rel="noopener noreferrer"
  {%- endif -%}
  {{ block.shopify_attributes }}
>
  {{ block_settings.label }}
</a>

{% stylesheet %}
  .link {
    text-decoration: none;
    text-decoration-color: currentcolor;

    &:hover {
      color: var(--color-primary-hover);
      text-decoration-color: transparent;
    }
  }
{% endstylesheet %}
