{% liquid
  assign color_scheme = section.settings.color_scheme
%}

{% style %}
  {%- unless section.settings.use_theme_fonts -%}
    {%- if section.settings.subheading_custom_font == blank -%}
      {{ section.settings.subheading_font | font_face: font_display: 'swap' }}
    {%- endif -%}
    {%- if section.settings.heading_custom_font == blank -%}
      {{ section.settings.heading_font | font_face: font_display: 'swap' }}
    {%- endif -%}
    {%- if section.settings.description_custom_font == blank -%}
      {{ section.settings.description_font | font_face: font_display: 'swap' }}
    {%- endif -%}
    {%- if section.settings.blocks_custom_font == blank -%}
      {{ section.settings.blocks_font | font_face: font_display: 'swap' }}
    {%- endif -%}
    {%- if section.settings.button_custom_font == blank -%}
      {{ section.settings.button_font | font_face: font_display: 'swap' }}
    {%- endif -%}
  {%- endunless -%}

  .aboutsk--{{ section.id }} {
    --section-min-height-desktop: {{ section.settings.section_min_height }}px;
    --section-min-height-mobile: {{ section.settings.section_min_height_mobile }}px;
    --section-padding-top: {{ section.settings.padding_block_start }}px;
    --section-padding-bottom: {{ section.settings.padding_block_end }}px;
    --section-padding-left: {{ section.settings.padding_inline_start }}px;
    --section-padding-right: {{ section.settings.padding_inline_end }}px;

    /* Subheading Typography */
    {% if section.settings.use_theme_fonts %}
      --subheading-font-family: var(--font-subheading--family, inherit);
    {% elsif section.settings.subheading_custom_font != blank %}
      --subheading-font-family: {{ section.settings.subheading_custom_font }};
    {% else %}
      --subheading-font-family: {{ section.settings.subheading_font.family }}, {{ section.settings.subheading_font.fallback_families }};
    {% endif %}
    --subheading-font-size: {{ section.settings.subheading_size }}px;
    --subheading-font-weight: {{ section.settings.subheading_weight }};
    --subheading-color: {{ section.settings.subheading_color }};

    /* Heading Typography */
    {% if section.settings.use_theme_fonts %}
      --heading-font-family: var(--font-heading--family, inherit);
    {% elsif section.settings.heading_custom_font != blank %}
      --heading-font-family: {{ section.settings.heading_custom_font }};
    {% else %}
      --heading-font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    {% endif %}
    --heading-font-size: {{ section.settings.heading_size }}px;
    --heading-font-weight: {{ section.settings.heading_weight }};
    --heading-color: {{ section.settings.heading_color }};
    --heading-highlight-color: {{ section.settings.heading_highlight_color }};

    /* Description Typography */
    {% if section.settings.use_theme_fonts %}
      --description-font-family: var(--font-body--family, inherit);
    {% elsif section.settings.description_custom_font != blank %}
      --description-font-family: {{ section.settings.description_custom_font }};
    {% else %}
      --description-font-family: {{ section.settings.description_font.family }}, {{ section.settings.description_font.fallback_families }};
    {% endif %}
    --description-font-size: {{ section.settings.description_size }}px;
    --description-font-weight: {{ section.settings.description_weight }};
    --description-color: {{ section.settings.description_color }};

    /* Blocks Typography */
    {% if section.settings.use_theme_fonts %}
      --blocks-font-family: var(--font-body--family, inherit);
    {% elsif section.settings.blocks_custom_font != blank %}
      --blocks-font-family: {{ section.settings.blocks_custom_font }};
    {% else %}
      --blocks-font-family: {{ section.settings.blocks_font.family }}, {{ section.settings.blocks_font.fallback_families }};
    {% endif %}
    --blocks-value-size: {{ section.settings.blocks_value_size }}px;
    --blocks-value-weight: {{ section.settings.blocks_value_weight }};
    --blocks-value-color: {{ section.settings.blocks_value_color }};
    --blocks-label-size: {{ section.settings.blocks_label_size }}px;
    --blocks-label-weight: {{ section.settings.blocks_label_weight }};
    --blocks-label-color: {{ section.settings.blocks_label_color }};
    --blocks-bg-color: {{ section.settings.blocks_bg_color }};
    --blocks-border-color: {{ section.settings.blocks_border_color }};

    /* Button Typography & Styling */
    {% if section.settings.use_theme_fonts %}
      --button-font-family: var(--font-body--family, inherit);
    {% elsif section.settings.button_custom_font != blank %}
      --button-font-family: {{ section.settings.button_custom_font }};
    {% else %}
      --button-font-family: {{ section.settings.button_font.family }}, {{ section.settings.button_font.fallback_families }};
    {% endif %}
    --button-font-size: {{ section.settings.button_size }}px;
    --button-font-weight: {{ section.settings.button_weight }};
    --button-color: {{ section.settings.button_color }};
    --button-bg-color: {{ section.settings.button_bg_color }};
    --button-hover-color: {{ section.settings.button_hover_color }};
    --button-hover-bg-color: {{ section.settings.button_hover_bg_color }};
    --button-border-radius: {{ section.settings.button_radius }}px;
    --button-border-color: {{ section.settings.button_border_color }};
    --button-border-width: {{ section.settings.button_border_width }}px;
  }

  .aboutsk--{{ section.id }} {
    min-height: var(--section-min-height-mobile);
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    padding-left: var(--section-padding-left);
    padding-right: var(--section-padding-right);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 990px) {
    .aboutsk--{{ section.id }} {
      min-height: var(--section-min-height-desktop);
    }
  }

  .aboutsk__container--{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
    justify-items: center;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  @media screen and (min-width: 990px) {
    .aboutsk__container--{{ section.id }} {
      grid-template-columns: 1fr 1.05fr;
      gap: 60px;
    }
  }

  /* Left Collage CSS */
  .aboutsk__collage-wrapper {
    position: relative;
    width: 100%;
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media screen and (min-width: 990px) {
    .aboutsk__collage-wrapper {
      height: 480px;
    }
  }

  .aboutsk__collage {
    position: relative;
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: 16px;
    width: 95%;
    height: 100%;
  }

  .aboutsk__collage-left-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
    justify-content: center;
  }

  /* Custom slanted skew shapes */
  .aboutsk__collage-shape {
    position: relative;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    box-sizing: border-box;
    border: 4px solid #ffffff;
  }

  .aboutsk__collage-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Sprout Wrapper (Top Left) */
  .aboutsk__collage-sprout-wrapper {
    height: 52%;
    border-radius: 120px 20px 20px 20px;
    margin-left: 20px;
    transform: skew(-13deg, 6deg);
  }

  .aboutsk__collage-sprout-wrapper:hover {
    transform: skew(-13deg, 6deg) scale(1.02);
    z-index: 10;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
  }

  .aboutsk__collage-sprout-wrapper .aboutsk__collage-img {
    transform: skew(13deg, -6deg) scale(1.3);
  }

  .aboutsk__collage-sprout-wrapper:hover .aboutsk__collage-img {
    transform: skew(13deg, -6deg) scale(1.35);
  }

  /* Farmer Wrapper (Bottom Left) */
  .aboutsk__collage-farmer-wrapper {
    height: 44%;
    border-radius: 20px 20px 20px 120px;
    margin-left: 5px;
    transform: skew(-13deg, 6deg);
  }

  .aboutsk__collage-farmer-wrapper:hover {
    transform: skew(-13deg, 6deg) scale(1.02);
    z-index: 10;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
  }

  .aboutsk__collage-farmer-wrapper .aboutsk__collage-img {
    transform: skew(13deg, -6deg) scale(1.3);
  }

  .aboutsk__collage-farmer-wrapper:hover .aboutsk__collage-img {
    transform: skew(13deg, -6deg) scale(1.35);
  }

  /* Storefront Wrapper (Right Side Parallelogram) */
  .aboutsk__collage-storefront-wrapper {
    height: 96%;
    align-self: center;
    border-radius: 24px 80px 24px 80px;
    z-index: 2;
    transform: skewX(-13deg);
  }

  .aboutsk__collage-storefront-wrapper:hover {
    transform: skewX(-13deg) scale(1.02);
    z-index: 10;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
  }

  .aboutsk__collage-storefront-wrapper .aboutsk__collage-img {
    transform: skewX(13deg) scale(1.25);
  }

  .aboutsk__collage-storefront-wrapper:hover .aboutsk__collage-img {
    transform: skewX(13deg) scale(1.3);
  }

  /* Diagonal Green Accent Bar on divider */
  .aboutsk__collage-accent-bar {
    position: absolute;
    left: -12px;
    top: 15%;
    height: 70%;
    width: 12px;
    background-color: #7BB828;
    transform: skewX(-13deg);
    border-radius: 6px;
    z-index: 1;
    display: none;
  }

  /* Thick Green Accent bar running on the right side of the building image */
  .aboutsk__collage-right-bar {
    position: absolute;
    right: -16px;
    top: 12%;
    height: 76%;
    width: 12px;
    background-color: #6FB236;
    transform: skewX(-13deg);
    border-radius: 6px;
    z-index: 1;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  }

  /* Right Content CSS */
  .aboutsk__content-col--{{ section.id }} {
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .aboutsk__subheading--{{ section.id }} {
    font-family: var(--subheading-font-family);
    font-size: var(--subheading-font-size);
    font-weight: var(--subheading-font-weight);
    color: var(--subheading-color);
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    text-transform: uppercase;
    display: inline-block;
  }

  .aboutsk__heading--{{ section.id }} {
    font-family: var(--heading-font-family);
    font-size: calc(var(--heading-font-size) * 0.78);
    font-weight: var(--heading-font-weight);
    color: var(--heading-color);
    line-height: 1.22;
    margin-top: 0;
    margin-bottom: 20px;
    letter-spacing: -0.015em;
  }

  @media screen and (min-width: 750px) {
    .aboutsk__heading--{{ section.id }} {
      font-size: var(--heading-font-size);
    }
  }

  .aboutsk__heading--{{ section.id }} strong,
  .aboutsk__heading--{{ section.id }} b {
    color: var(--heading-highlight-color);
    font-weight: inherit;
  }

  .aboutsk__description--{{ section.id }} {
    font-family: var(--description-font-family);
    font-size: var(--description-font-size);
    font-weight: var(--description-font-weight);
    color: var(--description-color);
    line-height: 1.62;
    margin-bottom: 28px;
    text-align: center;
  }

  .aboutsk__description--{{ section.id }} p {
    margin-top: 0;
    margin-bottom: 16px;
  }

  .aboutsk__description--{{ section.id }} p:last-child {
    margin-bottom: 0;
  }

  /* Bottom 4 Blocks CSS */
  .aboutsk__blocks-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    width: 100%;
    margin-bottom: 32px;
  }

  @media screen and (min-width: 480px) {
    .aboutsk__blocks-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1200px) {
    .aboutsk__blocks-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .aboutsk__block-card {
    background-color: var(--blocks-bg-color);
    border: 1px solid var(--blocks-border-color);
    border-radius: 12px;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .aboutsk__block-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(111, 178, 54, 0.08);
    border-color: rgba(111, 178, 54, 0.3);
  }

  .aboutsk__block-icon-wrapper {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background-color: rgba(111, 178, 54, 0.08);
    color: #6FB236;
  }

  .aboutsk__block-icon-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .aboutsk__block-info {
    display: flex;
    flex-direction: column;
  }

  .aboutsk__block-value {
    font-family: var(--blocks-font-family);
    font-size: var(--blocks-value-size);
    font-weight: var(--blocks-value-weight);
    color: var(--blocks-value-color);
    line-height: 1.1;
  }

  .aboutsk__block-label {
    font-family: var(--blocks-font-family);
    font-size: var(--blocks-label-size);
    font-weight: var(--blocks-label-weight);
    color: var(--blocks-label-color);
    line-height: 1.2;
    margin-top: 2px;
  }

  /* Button Custom Styling */
  .aboutsk__button-container {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .aboutsk__button--{{ section.id }} {
    font-family: var(--button-font-family);
    font-size: var(--button-font-size);
    font-weight: var(--button-font-weight);
    color: var(--button-color);
    background-color: var(--button-bg-color);
    border-radius: var(--button-border-radius);
    border: var(--button-border-width) solid var(--button-border-color);
    padding: 14px 28px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 4px 15px rgba(111, 178, 54, 0.15);
    cursor: pointer;
  }

  .aboutsk__button--{{ section.id }}:hover {
    transform: translateY(-2px);
    color: var(--button-hover-color);
    background-color: var(--button-hover-bg-color);
    border-color: var(--button-hover-bg-color);
    box-shadow: 0 6px 20px rgba(111, 178, 54, 0.25);
  }

  .aboutsk__button-icon {
    width: 18px;
    height: 18px;
    fill: currentColor;
    transition: transform 0.25s ease;
  }

  .aboutsk__button--{{ section.id }}:hover .aboutsk__button-icon {
    transform: translateX(4px);
  }

  /* Elegant floating background leaf decorations */
  .aboutsk__bg-decor-1 {
    position: absolute;
    right: -60px;
    top: 15%;
    width: 200px;
    height: 200px;
    opacity: 0.08;
    pointer-events: none;
    transform: rotate(25deg);
    z-index: 1;
  }

  .aboutsk__bg-decor-2 {
    position: absolute;
    right: 20px;
    bottom: 10%;
    width: 150px;
    height: 150px;
    opacity: 0.06;
    pointer-events: none;
    transform: rotate(-15deg);
    z-index: 1;
  }
{% endstyle %}

<div class="aboutsk aboutsk--{{ section.id }} color-{{ color_scheme }}">
  <!-- Background Decorations -->
  {%- if section.settings.show_decorations -%}
    <div class="aboutsk__bg-decor-1">
      <svg viewBox="0 0 100 100" fill="#6FB236">
        <path d="M50 0C50 0 20 30 20 60C20 76.5 33.5 90 50 90C66.5 90 80 76.5 80 60C80 30 50 0 50 0ZM50 82C37.8 82 28 72.2 28 60C28 42 46.2 19 50 14.5C53.8 19 72 42 72 60C72 72.2 62.2 82 50 82Z"/>
      </svg>
    </div>
    <div class="aboutsk__bg-decor-2">
      <svg viewBox="0 0 100 100" fill="#6FB236">
        <path d="M50 10C30 30 30 60 50 90C70 60 70 30 50 10ZM50 78C40 55 42 35 50 22C58 35 60 55 50 78Z"/>
      </svg>
    </div>
  {%- endif -%}

  <div class="aboutsk__container aboutsk__container--{{ section.id }} page-width">
    <!-- Left Column: Images Collage -->
    <div class="aboutsk__collage-wrapper">
      <div class="aboutsk__collage">
        <div class="aboutsk__collage-left-col">
          <!-- Top Left Sprout Image -->
          <div class="aboutsk__collage-shape aboutsk__collage-sprout-wrapper">
            {%- if section.settings.image_1 != blank -%}
              <img
                src="{{ section.settings.image_1 | image_url: width: 600 }}"
                alt="{{ section.settings.image_1.alt | escape }}"
                loading="lazy"
                width="{{ section.settings.image_1.width }}"
                height="{{ section.settings.image_1.height }}"
                class="aboutsk__collage-img"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg aboutsk__collage-img' }}
            {%- endif -%}
          </div>

          <!-- Bottom Left Farmer Image -->
          <div class="aboutsk__collage-shape aboutsk__collage-farmer-wrapper">
            {%- if section.settings.image_2 != blank -%}
              <img
                src="{{ section.settings.image_2 | image_url: width: 600 }}"
                alt="{{ section.settings.image_2.alt | escape }}"
                loading="lazy"
                width="{{ section.settings.image_2.width }}"
                height="{{ section.settings.image_2.height }}"
                class="aboutsk__collage-img"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg aboutsk__collage-img' }}
            {%- endif -%}
          </div>
        </div>

        <!-- Storefront Image -->
        <div class="aboutsk__collage-shape aboutsk__collage-storefront-wrapper">
          {%- if section.settings.image_3 != blank -%}
            <img
              src="{{ section.settings.image_3 | image_url: width: 800 }}"
              alt="{{ section.settings.image_3.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.image_3.width }}"
              height="{{ section.settings.image_3.height }}"
              class="aboutsk__collage-img"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg aboutsk__collage-img' }}
          {%- endif -%}

          <!-- Green Diagonal Stripe on Storefront Left Divider -->
          <div class="aboutsk__collage-accent-bar"></div>
          
          <!-- Green Accent Bar on the right side of the image -->
          <div class="aboutsk__collage-right-bar"></div>
        </div>
      </div>
    </div>

    <!-- Right Column: Content -->
    <div class="aboutsk__content-col aboutsk__content-col--{{ section.id }}">
      {%- if section.settings.subheading_text != blank -%}
        <span class="aboutsk__subheading aboutsk__subheading--{{ section.id }}">
          {{- section.settings.subheading_text | escape -}}
        </span>
      {%- endif -%}

      {%- if section.settings.heading_text != blank -%}
        <h2 class="aboutsk__heading aboutsk__heading--{{ section.id }}">
          {{- section.settings.heading_text -}}
        </h2>
      {%- endif -%}

      {%- if section.settings.description_text != blank -%}
        <div class="aboutsk__description aboutsk__description--{{ section.id }} rte">
          {{ section.settings.description_text }}
        </div>
      {%- endif -%}

      <!-- 4 Custom Blocks Grid -->
      <div class="aboutsk__blocks-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'metric_block' -%}
            <div class="aboutsk__block-card" {{ block.shopify_attributes }}>
              <div class="aboutsk__block-icon-wrapper">
                {%- if block.settings.icon_image != blank -%}
                  <img
                    src="{{ block.settings.icon_image | image_url: width: 100 }}"
                    alt="{{ block.settings.icon_image.alt | escape }}"
                    loading="lazy"
                    width="40"
                    height="40"
                    class="aboutsk__block-icon-image"
                  >
                {%- else -%}
                  <!-- High Quality SVG Defaults -->
                  {%- case block.settings.default_icon -%}
                    {%- when 'products' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"></polygon>
                        <line x1="12" y1="22" x2="12" y2="15.5"></line>
                        <polyline points="22 8.5 12 15.5 2 8.5"></polyline>
                        <polyline points="2 15.5 12 8.5 22 15.5"></polyline>
                        <line x1="12" y1="2" x2="12" y2="8.5"></line>
                      </svg>
                    {%- when 'farmers' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                      </svg>
                    {%- when 'distributors' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                        <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                      </svg>
                    {%- when 'states' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                      </svg>
                    {%- else -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="16"></line>
                        <line x1="8" y1="12" x2="16" y2="12"></line>
                      </svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>
              <div class="aboutsk__block-info">
                <span class="aboutsk__block-value">{{ block.settings.value_text | escape }}</span>
                <span class="aboutsk__block-label">{{ block.settings.label_text | escape }}</span>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Button CTA -->
      {%- if section.settings.button_label != blank -%}
        <div class="aboutsk__button-container">
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="aboutsk__button aboutsk__button--{{ section.id }}"
          >
            <!-- Leaf SVG Icon matching image -->
            <svg class="aboutsk__button-icon" viewBox="0 0 24 24">
              <path d="M17 8C8 8 4 14 4 20C4 20 8 16 13 16C13 16 12 17 11 18C15 18 19 14 20 10C20 9 19 8 17 8ZM14.3 14C11.3 14 8.7 15.3 7 17.2C8 14.3 10.7 11.5 14.5 10.8C14.7 11.8 14.6 13 14.3 14Z" />
            </svg>
            <span>{{ section.settings.button_label | escape }}</span>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

