
{% render 'button', link: block.settings.link %}

{% schema %}
{
  "name": "t:names.button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label",
      "default": "t:text_defaults.button_label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "t:settings.style",
      "options": [
        {
          "value": "button",
          "label": "t:options.primary"
        },
        {
          "value": "button-secondary",
          "label": "t:options.secondary"
        },
        {
          "value": "link",
          "label": "t:options.link"
        }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == \"custom\" }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == \"custom\" }}"
    },
    {
      "type": "header",
      "content": "Custom Typography Settings"
    },
    {
      "type": "checkbox",
      "id": "use_custom_typography",
      "label": "Enable Custom Typography",
      "default": false
    },
    {
      "type": "select",
      "id": "custom_font_family",
      "label": "Font Family",
      "options": [
        {
          "value": "var(--font-body--family)",
          "label": "Body"
        },
        {
          "value": "var(--font-subheading--family)",
          "label": "Subheading"
        },
        {
          "value": "var(--font-heading--family)",
          "label": "Heading"
        },
        {
          "value": "var(--font-accent--family)",
          "label": "Accent"
        }
      ],
      "default": "var(--font-body--family)",
      "visible_if": "{{ block.settings.use_custom_typography }}"
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "label": "Font Size",
      "min": 8,
      "max": 150,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.use_custom_typography }}"
    },
    {
      "type": "select",
      "id": "custom_font_weight",
      "label": "Font Weight",
      "options": [
        {
          "value": "100",
          "label": "100 - Thin"
        },
        {
          "value": "200",
          "label": "200 - Extra Light"
        },
        {
          "value": "300",
          "label": "300 - Light"
        },
        {
          "value": "400",
          "label": "400 - Normal"
        },
        {
          "value": "500",
          "label": "500 - Medium"
        },
        {
          "value": "600",
          "label": "600 - Semi Bold"
        },
        {
          "value": "700",
          "label": "700 - Bold"
        },
        {
          "value": "800",
          "label": "800 - Extra Bold"
        },
        {
          "value": "900",
          "label": "900 - Black"
        }
      ],
      "default": "400",
      "visible_if": "{{ block.settings.use_custom_typography }}"
    },
    {
      "type": "color",
      "id": "custom_font_color",
      "label": "Font Color",
      "default": "#000000",
      "visible_if": "{{ block.settings.use_custom_typography }}"
    },
    {
      "type": "range",
      "id": "custom_letter_spacing",
      "label": "Letter Spacing",
      "min": -5,
      "max": 15,
      "step": 0.5,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.use_custom_typography }}"
    },
    {
      "type": "range",
      "id": "custom_word_spacing",
      "label": "Word Spacing",
      "min": -5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.use_custom_typography }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.button",
      "category": "t:categories.basic",
      "settings": {
        "link": "shopify://collections/all"
      }
    }
  ]
}
{% endschema %}
